# Backend : groq (défaut, API Groq) | ollama (local)
# AGENT_BACKEND=groq

# 0 = prompts complets (défaut, meilleure qualité). 1 = prompt court + cache web (moins de tokens, utile si 429 Groq).
# AGENT_PERFORMANCE_MODE=0
# AGENT_MAX_TOOL_ROUNDS=16
# WEB_SEARCH_CACHE_TTL_SEC=120
# WEB_SEARCH_CACHE_MAX_ENTRIES=96
# MAX_READ_BYTES=450000
# MAX_SHELL_OUTPUT=28000

# --- Groq (https://console.groq.com/keys) ---
GROQ_API_KEY=ta_cle_groq_ici
# Modèles courants : llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_REQUEST_TIMEOUT_SEC=120
# Température 0–2 (défaut 0.65 : plus stable que le défaut API souvent trop « créatif »)
# GROQ_TEMPERATURE=0.65
# Historique envoyé à chaque tour (défaut 48). Plus haut = plus de risque 429 TPM sur le tier gratuit.
# GROQ_MAX_HISTORY_MESSAGES=48
# Plafond de tokens pour la réponse du modèle (0 = défaut API). Ex. 8192 pour réponses très longues.
# GROQ_MAX_COMPLETION_TOKENS=0
# Nouveaux essais automatiques sur erreur 429 (limite de débit), avec attente suggérée par l’API.
# GROQ_RATE_LIMIT_MAX_RETRIES=8

# Journal mémoire sur disque (relatif au workspace)
# LOCAL_MEMORY_JOURNAL=memory/journal.md
# MAX_MEMORY_JOURNAL_BYTES=2000000
# MAX_MEMORY_READ_CHARS=120000

# Créateur (affiché au modèle : il sait qui le contrôle)
# AGENT_OWNER_NAME=Prénom
# Indices pour recherches web sur toi (pseudo LinkedIn, GitHub, etc.)
# AGENT_OWNER_ONLINE_HINT=
# 1 = outil fetch_url (page web → texte ; ce n’est pas @Browser / Playwright)
# ALLOW_FETCH_URL=0
# MAX_FETCH_URL_BYTES=500000
# FETCH_URL_TIMEOUT_SEC=25

# Navigateur : ouvrir URLs + ouvrir wa.me depuis l’agent (confirmation à chaque fois)
# ALLOW_OPEN_BROWSER=0

# E-mail SMTP (Gmail : activer 2FA + mot de passe d’application)
# ALLOW_SMTP_SEND=0
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=1
# MAX_EMAIL_BODY_CHARS=200000

# --- Ollama (si AGENT_BACKEND=ollama) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_TEMPERATURE=0.65
# OLLAMA_CRITIC_MODEL=
# OLLAMA_REQUEST_TIMEOUT_SEC=600
# OLLAMA_NUM_CTX=8192
# OLLAMA_MAX_HISTORY_MESSAGES=48

# Auto-évaluation (ollama uniquement) : 1 | 0
# SELF_EVAL=1
# SELF_EVAL_MIN_SCORE=7

# Dossier de travail de l'agent (chemins relatifs y sont confinés)
# WORKSPACE_ROOT=C:\chemin\vers\ton\workspace

# 1 = autorise run_powershell (dangereux si mal utilisé)
# ALLOW_POWERSHELL=0
