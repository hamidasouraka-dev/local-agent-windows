# ============================================================
# SAISA v2 Configuration
# ============================================================

# Provider: ollama (local, default), groq, openai, anthropic
SAISA_PROVIDER=ollama

# ── Ollama (local inference) ──────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# ── Groq (fast cloud) ────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Agent Settings ────────────────────────────────────────────
SAISA_TEMPERATURE=0.3
SAISA_MAX_TOOL_ROUNDS=30
SAISA_MAX_CONTEXT=60
SAISA_TIMEOUT=300
SAISA_STREAMING=1

# ── Permissions ───────────────────────────────────────────────
SAISA_ALLOW_SHELL=1
SAISA_ALLOW_GIT=1

# ── Identity ──────────────────────────────────────────────────
SAISA_NAME=SAISA
SAISA_OWNER=

# ── Workspace (default: current directory) ────────────────────
# SAISA_WORKSPACE=/path/to/your/project

# ── Sessions directory ────────────────────────────────────────
# SAISA_SESSIONS_DIR=~/.saisa/sessions

# ============================================================
